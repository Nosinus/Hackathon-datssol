# Generic competition defaults
DATASTEAM_GAME=datsblack
DATASTEAM_API_BASE_URL=https://datsblack.datsteam.dev
DATASTEAM_API_KEY=replace_me
DATASTEAM_AUTH_HEADER=X-API-Key
DATASTEAM_TIMEOUT_SECONDS=1.5
DATASTEAM_RETRIES=1
DATASTEAM_REPLAY_DIR=logs/replay
DATASTEAM_BACKOFF_INITIAL_SECONDS=0.2
DATASTEAM_BACKOFF_MULTIPLIER=2.0
DATASTEAM_BACKOFF_MAX_SECONDS=2.0
DATASTEAM_ACCEPT_GZIP=true

# DatsBlack adapter options
DATASTEAM_DATSBLACK_MODE=royal
DATASTEAM_DATSBLACK_ENABLE_LONG_SCAN=true
DATASTEAM_DATSBLACK_MAP_CACHE_DIR=logs/maps
